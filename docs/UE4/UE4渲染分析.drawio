                <mxCell id="IcXdfvn6SKq59hyuqCsZ-92" value="FDefaultMaterialInstance：渲染UMaterial的默认代表实例。&#10;FMaterialInstanceResource：渲染UMaterialInstance实例的代表。&#10;FColoredMaterialRenderProxy：覆盖材质颜色向量参数的材质渲染代表。&#10;FLandscapeMaskMaterialRenderProxy：地貌遮罩材质渲染代表。&#10;FLightmassMaterialProxy：Lightmass材质渲染代理。" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=10;strokeWidth=1;strokeColor=default;" vertex="1" parent="IcXdfvn6SKq59hyuqCsZ-91">
