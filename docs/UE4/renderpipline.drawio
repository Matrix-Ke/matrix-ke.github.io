                <mxCell id="70" value="设置渲染状态&lt;br&gt;" style="whiteSpace=wrap;html=1;sketch=0;strokeColor=#457B9D;fontColor=#1D3557;fillColor=#C4D3AA;arcSize=0;" parent="1" vertex="1">
                    <mxGeometry x="374" y="345" width="130" height="40" as="geometry"/>
