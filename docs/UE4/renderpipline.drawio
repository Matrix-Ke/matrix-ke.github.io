                <mxCell id="55" value="&lt;span style=&quot;color: rgb(29 , 53 , 87)&quot;&gt;应用程序阶段&lt;br&gt;&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="240" y="325" width="94" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="64" value="&lt;h1&gt;CPU阶段&lt;/h1&gt;&lt;p&gt;CPU不会和GPU直接通讯，但是可以queue队列（command buffer/ ring buffer /ring 环形缓冲区） 完成通信。当CPU请求GPU绘制是，分两步完成：&lt;/p&gt;&lt;p&gt;1. 设置渲染状态（顶点，材质纹理， 灯光等）--这个过程的同时数据从内存加载到显存&lt;/p&gt;&lt;p&gt;2. 调用drawcall，绘制mesh，绘制所有使用相同状态进行渲染的网格； 对于渲染状态不同的mesh， 要再次设置渲染状态， 因为设置渲染状态heavy所以才需要batch批处理。所以队列中大概是：renderstate， DrawA，DrawB： RenderState， DrawC， DrawD.......&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="50" y="20" width="880" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="65" value="" style="endArrow=blockThin;html=1;fontColor=#333333;endFill=1;strokeColor=#1A1A1A;dashed=1;dashPattern=1 4;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="18" target="69" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="520" y="240" as="sourcePoint"/>
                        <mxPoint x="810" y="240" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="69" value="所需从硬盘HDD加载到系统内存RAM， 网格和纹理数据再被加载到显存VRAM" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="850" y="200" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="78" value="" style="edgeStyle=orthogonalEdgeStyle;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;strokeColor=#1A1A1A;strokeWidth=2;fontColor=#333333;" parent="1" source="70" target="75" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
